---
const contact = {
  email:    'botek.b1991@gmail.com',
  location: 'La Plata, Buenos Aires, Argentina',
  linkedin: 'https://www.linkedin.com/in/', // TODO: completar URL
  github:   'https://github.com/',           // TODO: completar URL
};
---
<section id="contacto" class="relative px-6 md:px-12 pt-24 md:pt-32 pb-40 md:pb-56" style="
  background:
    linear-gradient(to bottom, #0e0f11 0%, rgba(14,15,17,0) 80%),
    radial-gradient(ellipse 160% 80% at 50% 108%,
      #ffffff       5%,
      #fff3b0       7%,
      #ffb347      17%,
      #ff6030      30%,
      #e0305a      44%,
      #8b1a8b      60%,
      #3d1260      74%,
      #0e0f11      88%
    );
">

  <div class="max-w-[1200px] mx-auto">

    <div class="mb-16">
      <span class="font-mono text-md uppercase tracking-[1.4px] text-white/30">— Hablemos</span>
      <h2 class="font-mono font-light text-3xl md:text-4xl text-white mt-3">Contacto</h2>
    </div>

    <p class="font-sans text-base text-white/40 max-w-sm leading-relaxed mb-10">
      Abierto a nuevas oportunidades, proyectos de consultoría y colaboraciones en automatización, IoT e inteligencia artificial.
    </p>

    <div class="max-w-lg space-y-px">
      <a
        href={`mailto:${contact.email}`}
        class="group flex items-center justify-between bg-white/[0.03] hover:bg-white/[0.06] border border-white/10 hover:border-white/20 px-6 py-4 transition-all duration-200"
      >
        <div>
          <span class="font-mono text-[10px] uppercase tracking-[1px] text-white/30 block mb-1">Email</span>
          <span class="font-sans text-sm text-white/60 group-hover:text-white/40 transition-colors duration-200">{contact.email}</span>
        </div>
        <span class="font-mono text-sm text-white/20 group-hover:text-white/10 transition-colors duration-200">→</span>
      </a>

      <a
        href={contact.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center justify-between bg-white/[0.03] hover:bg-white/[0.06] border border-white/10 hover:border-white/20 px-6 py-4 transition-all duration-200"
      >
        <div>
          <span class="font-mono text-[10px] uppercase tracking-[1px] text-white/30 block mb-1">LinkedIn</span>
          <span class="font-sans text-sm text-white/60 group-hover:text-white/40 transition-colors duration-200">linkedin.com/in/christian-castro-botek</span>
        </div>
        <span class="font-mono text-sm text-white/20 group-hover:text-white/10 transition-colors duration-200">↗</span>
      </a>

      <a
        href={contact.github}
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center justify-between bg-white/[0.03] hover:bg-white/[0.06] border border-white/10 hover:border-white/20 px-6 py-4 transition-all duration-200"
      >
        <div>
          <span class="font-mono text-[10px] uppercase tracking-[1px] text-white/30 block mb-1">GitHub</span>
          <span class="font-sans text-sm text-white/60 group-hover:text-white/40 transition-colors duration-200">github.com/TODO</span>
        </div>
        <span class="font-mono text-sm text-white/20 group-hover:text-white/10 transition-colors duration-200">↗</span>
      </a>
    </div>

    <a
      href={`${import.meta.env.BASE_URL}cv_1.pdf`}
      download="CV_BOTEK-Ing-Electronico.pdf"
      class="inline-flex items-center gap-3 font-mono text-xs uppercase tracking-[1.4px] border border-white/20 text-white/50 hover:bg-white/5 hover:text-white transition-colors duration-200 px-6 py-3 mt-6"
    >
      Descargar CV ↓
    </a>

    <p class="mt-4 font-sans text-xs text-white/25">{contact.location}</p>

  </div>

  <!-- Back to top button -->
  <a
    href="#"
    data-go-home
    aria-label="Volver al inicio"
    class="absolute bottom-12 left-1/2 -translate-x-1/2 flex flex-col items-center group"
  >
    <div class="px-6 py-2 rounded-full bg-black/20 backdrop-blur-sm flex flex-col items-center justify-center transition-all duration-500 hover:bg-white/30">

      <svg
        width="18" height="18" viewBox="0 0 24 24" fill="none"
        stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
        class="text-white/40 group-hover:text-white/80 transition-colors duration-300"
      >
        <path d="M12 19V5M5 12l7-7 7 7"/>
      </svg>

      <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-white/30 group-hover:text-white/60 transition-colors duration-300">
        Inicio
      </span>

    </div>

    <div class="w-full h-[1px] bg-gradient-to-r from-transparent via-white/10 to-transparent mt-2 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
  </a>

</section>
