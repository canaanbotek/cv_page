---
import BlackholeBackground from './BlackholeBackground.astro';

const phases = [
  {
    n: '01',
    label: 'Entender',
    summary: 'Problema, contexto y sistema completo',
    bullets: [
      'Identificación de causa raíz frente a síntomas superficiales',
      'Cuantificación del impacto: KPIs, baseline y puntos de dolor',
      'Análisis del escenario de inacción (cost of delay)',
      'Mapeo del flujo de punta a punta — dependencias e impactos cruzados',
    ],
    keywords: ['Root Cause Analysis', 'KPI Definition', 'Systems Thinking', 'Process Mapping'],
  },
  {
    n: '02',
    label: 'Definir',
    summary: 'KPIs, restricciones y objetivos',
    bullets: [
      'KPIs de éxito medibles y realistas',
      'Restricciones técnicas, presupuestarias y temporales',
      'Niveles de tolerancia al riesgo',
      'Alineación con la estrategia organizacional',
    ],
    keywords: ['KPI Design', 'Performance Metrics', 'Constraints Management', 'Strategic Alignment'],
  },
  {
    n: '03',
    label: 'Diseñar',
    summary: 'Alternativas y trade-offs',
    bullets: [
      'Exploración del espacio de soluciones — generación de alternativas',
      'Trade-offs: complejidad vs. impacto, costo vs. beneficio',
      'Priorización por valor incremental',
      'Validaciones tempranas de bajo costo antes de comprometer recursos',
    ],
    keywords: ['Solution Architecture', 'Trade-off Analysis', 'Experimentation', 'Risk Mitigation'],
  },
  {
    n: '04',
    label: 'Validar',
    summary: 'Prototipos, datos y aprendizaje',
    bullets: [
      'Prototipos funcionales bajo mentalidad MVP',
      'Evaluación del rendimiento en condiciones reales vs. baseline',
      'Identificación de brechas entre resultado esperado y obtenido',
      'Decisión basada en datos: escalar, iterar diseño o descartar',
    ],
    keywords: ['MVP Development', 'Data Analysis', 'Feedback Loop', 'Decision Making'],
    note: '↩ Si los datos lo reflejan, se regresa a Diseñar o reinicia el entendimiento para replantear el problema.',
  },
  {
    n: '05',
    label: 'Escalar',
    summary: 'Implementación e impacto real',
    bullets: [
      'Integración con ecosistemas existentes: ERPs, IoT, APIs de terceros',
      'Diseño para escalabilidad, alta disponibilidad y mantenibilidad',
      'Gestión del impacto en operadores y usuarios finales',
      'Capacitación, transferencia de conocimiento y adopción organizacional',
    ],
    keywords: ['System Integration', 'Scalability', 'Change Management', 'Process Adoption'],
  },
];
---

<section id="metodologia" class="relative px-6 md:px-12 py-24 md:py-32 border-t border-white/10 overflow-hidden">
  
  <div class="relative z-10 max-w-[1200px] mx-auto">

    <!-- Header -->
    <div class="mb-16">
      <span class="font-mono text-md uppercase tracking-[1.4px] text-white/30">— Metodología</span>
      <h2 class="font-mono font-light text-3xl md:text-4xl text-white mt-3">Del problema al impacto</h2>
      <p class="font-sans text-base text-white/50 max-w-xl mt-6 leading-relaxed">
        Es de vital importancia tomar decisiones basada en datos para la optimización e innovación de procesos.
        Un buen enfoque estructurado pero adaptable para diseñar, validar e implementar soluciones en sistemas complejos marcan un rumbo claro.
      </p>
    </div>

    <!-- Vertical phases -->
    <div class="border-t border-white/10">
      {phases.map(phase => (
        <div class="rf-phase border-b border-white/10 cursor-pointer" data-phase={phase.n}>

          <!-- Collapsed row -->
          <div class="py-5 grid grid-cols-[40px_1fr] md:grid-cols-[80px_1fr] gap-4 md:gap-8 items-baseline">
            <span class="font-mono text-xs text-white/30 pt-0.5">{phase.n}</span>
            <div>
              <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1">
                <span class="rf-label font-sans text-base text-white/70 transition-colors duration-200">
                  {phase.label}
                </span>
                <span class="rf-summary font-sans text-sm text-white/35 transition-colors duration-200">
                  {phase.summary}
                </span>
              </div>

              <!-- Expandable details -->
              <div class="rf-expand">
                <div class="pt-4 pb-2">
                  <ul class="space-y-2 mb-4">
                    {phase.bullets.map(b => (
                      <li class="font-sans text-sm text-white/45 flex gap-3 leading-relaxed">
                        <span class="text-white/20 shrink-0 select-none">—</span>
                        <span>{b}</span>
                      </li>
                    ))}
                  </ul>
                  {phase.note && (
                    <p class="font-mono text-[12px] uppercase tracking-[1.2px] text-white/22 mb-3">
                      {phase.note}
                    </p>
                  )}
                  <div class="flex flex-wrap gap-1.5">
                    {phase.keywords.map(k => (
                      <span class="font-mono text-[12px] uppercase tracking-[1px] text-white/30 border border-white/10 px-2 py-0.5">
                        {k}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .rf-expand {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.38s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .rf-phase.is-open .rf-expand  { max-height: 400px; }
  .rf-phase.is-open .rf-label   { color: rgba(255,255,255,0.90); }
  .rf-phase.is-open .rf-summary { color: rgba(255,255,255,0.50); }
</style>

<script>
(function () {
  const phases = Array.from(document.querySelectorAll('.rf-phase'));
  const isMd   = () => window.innerWidth >= 768;

  phases.forEach(phase => {
    phase.addEventListener('mouseenter', () => { if (isMd()) phase.classList.add('is-open'); });
    phase.addEventListener('mouseleave', () => { if (isMd()) phase.classList.remove('is-open'); });
    phase.addEventListener('click',      () => { phase.classList.toggle('is-open'); });
  });
})();
</script>
