---
import BlackholeBackground from './BlackholeBackground.astro';

interface Project {
  title:       string;
  description: string;
  tags:        string[];
  url?:        string;
  repo?:       string;
}

const projects: Project[] = [
  // Añadir proyectos aquí
];
---
<section id="proyectos" class="relative px-6 md:px-12 py-24 md:py-32 border-t border-white/10 overflow-hidden">
  <BlackholeBackground />
  <div class="relative z-10 max-w-[1200px] mx-auto">

    <div class="mb-16">
      <span class="font-mono text-xs uppercase tracking-[1.4px] text-white/30">— Trabajo</span>
      <h2 class="font-mono font-light text-3xl md:text-4xl text-white mt-3">Proyectos</h2>
    </div>

    {projects.length === 0 ? (
      <div class="border border-white/10 p-16 text-center">
        <p class="font-mono text-sm text-white/30 uppercase tracking-[1.4px]">Próximamente</p>
      </div>
    ) : (
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-px bg-white/10">
        {projects.map((project) => (
          <div class="bg-[#1f2228] p-8 hover:bg-white/[0.03] transition-colors duration-200">
            <h3 class="font-mono text-base text-white mb-3">{project.title}</h3>
            <p class="font-sans text-sm text-white/50 leading-relaxed mb-6">{project.description}</p>
            <div class="flex flex-wrap gap-2 mb-6">
              {project.tags.map(tag => (
                <span class="font-mono text-[10px] uppercase tracking-[1px] text-white/50 border border-white/10 px-2 py-1">
                  {tag}
                </span>
              ))}
            </div>
            <div class="flex gap-4">
              {project.url && (
                <a href={project.url} class="font-mono text-xs uppercase tracking-[1.4px] text-white hover:text-white/50 transition-colors duration-200">
                  Ver →
                </a>
              )}
              {project.repo && (
                <a href={project.repo} class="font-mono text-xs uppercase tracking-[1.4px] text-white/50 hover:text-white/30 transition-colors duration-200">
                  Repo →
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    )}

  </div>
</section>
