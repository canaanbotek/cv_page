---
const profile = {
  firstName:  'Christian Canaan',
  lastName:   'Castro Botek',
  title:      'Ingeniero Electrónico',
  specialty:  'Gestión de Producción, Logística y Digitalización de Procesos',
  bio:        'Especialista en optimización de procesos con expertise en automatización, tecnologías IoT e implementación de soluciones con sistemas de visión artificial y visualización de datos. Combino análisis estratégico con implementación técnica para desarrollar soluciones que mejoren la eficiencia operativa.',
  location:   'La Plata, Buenos Aires, Argentina',
  email:      'botek.b1991@gmail.com',
};
---
<section class="min-h-screen flex flex-col justify-center px-6 md:px-12 pt-14">
  <div class="max-w-[1200px] mx-auto w-full py-24 md:py-32 flex flex-col md:flex-row md:items-center gap-12 md:gap-16">

    <!-- Content -->
    <div class="flex-1 min-w-0">

      <div class="mb-8">
        <span class="font-mono text-xs uppercase tracking-[1.4px] text-white border border-white/20 px-2 py-1">
          {profile.title}
        </span>
      </div>

      <h1 class="font-mono font-light leading-[1.05] tracking-tight text-white mb-6">
        <span class="block text-[clamp(2.25rem,5.5vw,5rem)]">{profile.firstName}</span>
        <span class="block text-[clamp(2.25rem,5.5vw,5rem)]">{profile.lastName}</span>
      </h1>

      <p class="font-sans text-lg md:text-xl text-white/60 max-w-2xl mb-6 leading-snug">
        {profile.specialty}
      </p>

      <p class="font-sans text-base text-white/40 max-w-xl mb-12 leading-relaxed">
        {profile.bio}
      </p>

      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="#contacto"
          class="font-mono text-xs uppercase tracking-[1.4px] bg-white text-[#0e0f11] hover:bg-white/90 transition-colors duration-200 px-6 py-3 text-center"
        >
          Contactar
        </a>
        <a
          href="#experiencia"
          class="font-mono text-xs uppercase tracking-[1.4px] border border-white/20 text-white hover:bg-white/5 transition-colors duration-200 px-6 py-3 text-center"
        >
          Ver Experiencia
        </a>
        <a
          href={`${import.meta.env.BASE_URL}cv_1.pdf`}
          download="CV_BOTEK-Ing-Electronico.pdf"
          class="font-mono text-xs uppercase tracking-[1.4px] border border-white/20 text-white/50 hover:bg-white/5 hover:text-white transition-colors duration-200 px-6 py-3 text-center"
        >
          Descargar CV ↓
        </a>
      </div>

      <div class="mt-16 pt-8 border-t border-white/10 flex flex-wrap gap-x-8 gap-y-2">
        <span class="font-sans text-sm text-white/30">{profile.location}</span>
        <a
          href={`mailto:${profile.email}`}
          class="font-sans text-sm text-white/50 hover:text-white/30 transition-colors duration-200"
        >
          {profile.email}
        </a>
      </div>

    </div>

    <!-- Profile image -->
    <div class="shrink-0 self-start md:self-center">
      <img
        src={`${import.meta.env.BASE_URL}profile.jpeg`}
        alt="Christian Castro Botek"
        class="w-48 h-48 md:w-64 md:h-74 object-cover grayscale"
        style="mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 40%, transparent 100%); -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 40%, transparent 100%);"
      />
    </div>

  </div>
</section>
