---
const technicalGroups = [
  {
    category: 'Lenguajes & Frameworks',
    skills:   ['C/C++', 'Python', 'JavaScript', 'TypeScript', 'R', 'VueJS', 'Flask', 'NodeJs', 'ExpressJs'],
  },
  {
    category: 'IoT & Embebidos',
    skills:   ['Protocolos IoT', 'Firmware', 'Microcontroladores', 'RFID', 'KiCad', 'Altium'],
  },
  {
    category: 'IA & Datos',
    skills:   ['pandas', 'NumPy', 'Matplotlib', 'Seaborn', 'MediaPipe', 'OpenCV', 'TensorFlow Lite', 'RStudio', 'Jupyter'],
  },
  {
    category: 'Cloud & DevOps',
    skills:   ['AWS', 'AWS Amplify', 'AWS CloudFront', 'AWS API Gateway', 'AWS Lambda', 'Docker', 'Docker Compose', 'Git', 'GitLab', 'Jira'],
  },
  {
    category: 'Bases de Datos',
    skills:   ['SQL', 'PostgreSQL'],
  },
  {
    category: 'Herramientas',
    skills:   ['VSCode', 'LaTeX', 'ERP Tryton', 'Linux', 'Windows'],
  },
];

const softSkills = [
  'Negociación y gestión de expectativas',
  'Comunicación técnica y no técnica',
  'Adaptabilidad y aprendizaje continuo',
  'Pensamiento analítico',
  'Liderazgo colaborativo',
  'Capacitación y mentoring',
  'Orientación a resultados',
];

const languages = [
  { lang: 'Español', level: 'Nativo' },
  { lang: 'Inglés',  level: 'Intermedio' },
];
---
<section id="skills" class="px-6 md:px-12 py-24 md:py-32 border-t border-white/10">
  <div class="max-w-[1200px] mx-auto">

    <div class="mb-16">
      <span class="font-mono text-xs uppercase tracking-[1.4px] text-white/30">— Capacidades</span>
      <h2 class="font-mono font-light text-3xl md:text-4xl text-white mt-3">Skills</h2>
    </div>

    <!-- Technical skills -->
    <div class="space-y-8 mb-16">
      {technicalGroups.map((group) => (
        <div class="grid md:grid-cols-[200px_1fr] gap-4 md:gap-8">
          <span class="font-mono text-xs uppercase tracking-[1.4px] text-white/30 pt-1">
            {group.category}
          </span>
          <div class="flex flex-wrap gap-2">
            {group.skills.map((skill) => (
              <span class="font-mono text-xs uppercase tracking-[1px] text-white/70 border border-white/10 hover:border-white/20 transition-colors duration-200 px-2.5 py-1">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="border-t border-white/10 my-12"></div>

    <!-- Soft skills + languages -->
    <div class="grid md:grid-cols-2 gap-12">

      <div>
        <span class="font-mono text-xs uppercase tracking-[1.4px] text-white/30 block mb-6">
          Habilidades Blandas
        </span>
        <div class="flex flex-wrap gap-2">
          {softSkills.map((skill) => (
            <span class="font-sans text-sm text-white/50 border border-white/10 px-3 py-1.5">
              {skill}
            </span>
          ))}
        </div>
      </div>

      <div>
        <span class="font-mono text-xs uppercase tracking-[1.4px] text-white/30 block mb-6">
          Idiomas
        </span>
        <div class="space-y-0">
          {languages.map((item) => (
            <div class="flex items-center justify-between border-b border-white/10 py-4 last:border-0">
              <span class="font-sans text-base text-white">{item.lang}</span>
              <span class="font-mono text-xs uppercase tracking-[1px] text-white/40">{item.level}</span>
            </div>
          ))}
        </div>
      </div>

    </div>

  </div>
</section>
