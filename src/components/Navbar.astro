---
const links = [
  { label: 'Experiencia', href: '#experiencia' },
  { label: 'Educación',   href: '#educacion' },
  // { label: 'Proyectos',   href: '#proyectos' },
  { label: 'Skills',      href: '#skills' },
  { label: 'Emprendimiento', href: '#emprendimiento' },
];
---
<header class="fixed top-0 left-0 right-0 z-50 bg-[#0e0f11]/95 backdrop-blur-sm border-b border-white/10">
  <nav class="max-w-[1200px] mx-auto px-6 md:px-12 h-14 flex items-center justify-between">

    <a id="rocket-link" href="/cv_page" aria-label="Inicio" class="block w-10 h-10 shrink-0">
      <canvas id="rocket-canvas" width="40" height="40" class="block"></canvas>
    </a>

    <div class="hidden md:flex items-center gap-8">
      {links.map(link => (
        <a
          href={link.href}
          class="font-sans text-sm text-white/70 hover:text-white/40 transition-colors duration-200"
        >
          {link.label}
        </a>
      ))}
    </div>

    <a
      href="#contacto"
      class="hidden md:inline-flex items-center font-mono text-xs uppercase tracking-[1.4px] bg-white text-[#1f2228] hover:bg-white/90 transition-colors duration-200 px-5 py-2.5"
    >
      Contacto
    </a>

    <button
      id="mobile-menu-btn"
      class="md:hidden text-white hover:text-white/50 transition-colors"
      aria-label="Abrir menú"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square">
        <path d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </nav>

  <div id="mobile-menu" class="hidden md:hidden border-t border-white/10">
    <div class="max-w-[1200px] mx-auto px-6 py-4 flex flex-col gap-4">
      {links.map(link => (
        <a
          href={link.href}
          class="font-sans text-sm text-white/70 hover:text-white/40 transition-colors duration-200"
        >
          {link.label}
        </a>
      ))}
      <a
        href="#contacto"
        class="font-mono text-xs uppercase tracking-[1.4px] text-[#1f2228] bg-white px-5 py-2.5 text-center mt-2"
      >
        Contacto
      </a>
    </div>
  </div>
</header>

<script>
  // ── Mobile menu ──────────────────────────────────────────────────
  const btn  = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));

  // ── Rocket canvas ────────────────────────────────────────────────
  (function () {
    const canvas = document.getElementById('rocket-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const W = 40, H = 40;
    const CX = W / 2, CY = H / 2;
    const GROUND_Y = CY + 13;   // surface line — just below rocket fins

    // ── Physics ───────────────────────────────────────────────────
    let rocketVel   = 0;
    const DAMPING   = 0.88;
    const DEAD_ZONE = 0.04;

    // ── Landing state ─────────────────────────────────────────────
    let landed          = false;
    let landingFired    = false;  // burst spawns only once per landing
    let surfaceAlpha    = 0;      // lerped 0→1 on land, 1→0 on depart

    // ── Particles ─────────────────────────────────────────────────
    type Particle = {
      x: number; y: number;
      vx: number; vy: number;
      life: number; maxLife: number; r: number;
      kind: 'exhaust' | 'ambient' | 'dust';
    };
    const particles: Particle[] = [];

    function spawnScrollParticle() {
      if (rocketVel < 0) {
        particles.push({
          x: CX + (Math.random() - 0.5) * 3, y: CY + 9,
          vx: 0, vy: rocketVel * (0.8 + Math.random() * 0.4),
          life: 1, maxLife: 18 + Math.random() * 14,
          r: 0.6 + Math.random() * 0.8, kind: 'exhaust',
        });
      } else {
        particles.push({
          x: 2 + Math.random() * (W - 4), y: H + 2,
          vx: 0, vy: rocketVel * (0.35 + Math.random() * 0.25),
          life: 1, maxLife: 30 + Math.random() * 20,
          r: 0.3 + Math.random() * 0.45, kind: 'ambient',
        });
      }
    }

    function spawnLandingDust() {
      for (let i = 0; i < 16; i++) {
        const side = Math.random() < 0.5 ? -1 : 1;
        particles.push({
          x: CX + (Math.random() - 0.5) * 6,
          y: GROUND_Y - 1,
          vx: side * (0.5 + Math.random() * 1.8),
          vy: -(0.15 + Math.random() * 0.5),
          life: 1,
          maxLife: 45 + Math.random() * 35,
          r: 0.35 + Math.random() * 0.65,
          kind: 'dust',
        });
      }
    }

    // ── Draw surface line ─────────────────────────────────────────
    function drawSurface() {
      if (surfaceAlpha <= 0.01) return;
      const grad = ctx.createLinearGradient(0, 0, W, 0);
      grad.addColorStop(0,    'rgba(255,255,255,0)');
      grad.addColorStop(0.15, `rgba(255,255,255,${(surfaceAlpha * 0.55).toFixed(3)})`);
      grad.addColorStop(0.5,  `rgba(255,255,255,${(surfaceAlpha * 0.75).toFixed(3)})`);
      grad.addColorStop(0.85, `rgba(255,255,255,${(surfaceAlpha * 0.55).toFixed(3)})`);
      grad.addColorStop(1,    'rgba(255,255,255,0)');
      ctx.save();
      ctx.beginPath();
      ctx.moveTo(0, GROUND_Y);
      ctx.lineTo(W, GROUND_Y);
      ctx.strokeStyle = grad;
      ctx.lineWidth = 0.8;
      ctx.stroke();
      ctx.restore();
    }

    // ── Draw rocket ───────────────────────────────────────────────
    function drawRocket() {
      ctx.save();
      ctx.beginPath();
      ctx.moveTo(CX, CY - 11);
      ctx.bezierCurveTo(CX + 5, CY - 4, CX + 5, CY + 3, CX + 4, CY + 8);
      ctx.lineTo(CX - 4, CY + 8);
      ctx.bezierCurveTo(CX - 5, CY + 3, CX - 5, CY - 4, CX, CY - 11);
      ctx.closePath();
      ctx.fillStyle = 'rgba(255,255,255,0.85)';
      ctx.fill();

      ctx.beginPath();
      ctx.arc(CX, CY - 1, 2.2, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(14,15,17,0.9)';
      ctx.fill();
      ctx.strokeStyle = 'rgba(255,255,255,0.4)';
      ctx.lineWidth = 0.7;
      ctx.stroke();

      ctx.beginPath();
      ctx.moveTo(CX - 4, CY + 5);
      ctx.lineTo(CX - 8, CY + 10);
      ctx.lineTo(CX - 4, CY + 8);
      ctx.closePath();
      ctx.fillStyle = 'rgba(255,255,255,0.55)';
      ctx.fill();

      ctx.beginPath();
      ctx.moveTo(CX + 4, CY + 5);
      ctx.lineTo(CX + 8, CY + 10);
      ctx.lineTo(CX + 4, CY + 8);
      ctx.closePath();
      ctx.fillStyle = 'rgba(255,255,255,0.55)';
      ctx.fill();
      ctx.restore();
    }

    // ── Animation loop ────────────────────────────────────────────
    function frame() {
      ctx.clearRect(0, 0, W, H);

      // Lerp surface line alpha
      const targetAlpha = landed ? 1 : 0;
      surfaceAlpha += (targetAlpha - surfaceAlpha) * 0.07;

      // Decay velocity (blocked while fully landed)
      if (!landed) {
        rocketVel *= DAMPING;
        if (Math.abs(rocketVel) < DEAD_ZONE) rocketVel = 0;
      } else {
        rocketVel = 0;
      }

      // Spawn scroll particles (not while landed)
      if (!landed && Math.abs(rocketVel) > DEAD_ZONE) {
        const rate  = rocketVel < 0 ? 1.4 : 0.25;
        const count = Math.ceil(Math.abs(rocketVel) * rate);
        for (let i = 0; i < count; i++) spawnScrollParticle();
      }

      // Spawn landing dust burst (once)
      if (landed && !landingFired) {
        landingFired = true;
        spawnLandingDust();
      }

      // Draw surface behind everything
      drawSurface();

      // Update & draw particles
      for (let i = particles.length - 1; i >= 0; i--) {
        const p = particles[i];
        p.life -= 1 / p.maxLife;
        p.y    -= p.vy;
        p.x    += p.vx;

        if (p.kind === 'dust') {
          p.vx *= 0.90;
          p.vy *= 0.92;
        }

        if (p.life <= 0 || p.y < -2 || p.y > H + 2 || p.x < -4 || p.x > W + 4) {
          particles.splice(i, 1);
          continue;
        }

        const maxOpac = p.kind === 'ambient' ? 0.35 : p.kind === 'dust' ? 0.50 : 0.75;
        const opacity = Math.min(p.life * 1.8, 1) * maxOpac;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(255,255,255,${opacity.toFixed(3)})`;
        ctx.fill();
      }

      drawRocket();
      requestAnimationFrame(frame);
    }

    requestAnimationFrame(frame);

    // ── Scroll → velocity + bottom detection ──────────────────────
    let lastScrollY  = window.scrollY;
    let lastScrollAt = performance.now();

    function isAtBottom() {
      return window.scrollY + window.innerHeight >= document.documentElement.scrollHeight - 8;
    }

    function onScroll() {
      const now   = performance.now();
      const dy    = window.scrollY - lastScrollY;
      const dt    = Math.max(now - lastScrollAt, 8);
      const speed = dy / dt;

      const atBottom = isAtBottom();

      if (atBottom && !landed) {
        landed = true;
      } else if (!atBottom && landed) {
        // Departing from ground → ascent impulse
        landed       = false;
        landingFired = false;
        rocketVel    = -4.5;
      }

      if (!landed) {
        const impulse = Math.max(-4, Math.min(4, speed * 6));
        rocketVel += impulse * 0.55;
        rocketVel  = Math.max(-5, Math.min(5, rocketVel));
      }

      lastScrollY  = window.scrollY;
      lastScrollAt = now;
    }

    window.addEventListener('scroll', onScroll, { passive: true });

    // ── Click rocket / home buttons → ascent impulse ──────────────
    function triggerAscent() {
      landed       = false;
      landingFired = false;
      rocketVel    = -4.5;
    }

    document.getElementById('rocket-link')?.addEventListener('click', triggerAscent);
    document.querySelectorAll('[data-go-home]').forEach(el => {
      el.addEventListener('click', triggerAscent);
    });
  })();
</script>
