---
const id = 'bh-' + Math.random().toString(36).slice(2, 9);
---
<canvas
  id={id}
  class="absolute inset-0 w-full h-full pointer-events-none"
  aria-hidden="true"
></canvas>

<script define:vars={{ id }}>
(function () {
  const canvas = document.getElementById(id);
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  if (!ctx) return;

  const STAR_COUNT = 220;
  const MIN_RADIUS = 18;
  const MAX_RADIUS = 0.95;
  const DRIFT_SPEED = 0.018;
  const BASE_OPACITY = 0.32;

  let cx = 0, cy = 0, maxR = 0;
  let stars = [];
  let animId;

  function spawnStar(r) {
    const radius = r ?? (MIN_RADIUS * 2 + Math.random() * (maxR - MIN_RADIUS * 2));
    const speed = (0.0012 + Math.random() * 0.0008) * Math.pow(MIN_RADIUS * 3, 1.5) / Math.pow(radius, 1.5);
    return {
      r: radius,
      angle: Math.random() * Math.PI * 2,
      size: 0.4 + Math.random() * 0.9,
      speed: speed * (Math.random() < 0.5 ? 1 : -1),
      drift: (DRIFT_SPEED * 0.5 + Math.random() * DRIFT_SPEED) * 0.6,
    };
  }

  function resize() {
    const section = canvas.parentElement;
    canvas.width  = section.offsetWidth;
    canvas.height = section.offsetHeight;
    cx   = canvas.width  / 2;
    cy   = canvas.height / 2;
    maxR = Math.min(canvas.width, canvas.height) * MAX_RADIUS;
    stars = Array.from({ length: STAR_COUNT }, () => spawnStar());
  }

  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    const grad = ctx.createRadialGradient(cx, cy, 0, cx, cy, maxR * 0.55);
    grad.addColorStop(0,    'rgba(0,0,0,0.55)');
    grad.addColorStop(0.18, 'rgba(15,12,30,0.18)');
    grad.addColorStop(1,    'rgba(0,0,0,0)');
    ctx.fillStyle = grad;
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    for (const s of stars) {
      s.angle += s.speed;
      s.r -= s.drift;

      if (s.r < MIN_RADIUS) {
        const spawnR = maxR * (0.7 + Math.random() * 0.3);
        Object.assign(s, spawnStar(spawnR));
        continue;
      }

      const fadeNear = Math.min(1, (s.r - MIN_RADIUS) / (MIN_RADIUS * 3));
      const fadeFar  = Math.min(1, (maxR - s.r) / (maxR * 0.15));
      const opacity  = BASE_OPACITY * fadeNear * fadeFar;

      const x = cx + Math.cos(s.angle) * s.r;
      const y = cy + Math.sin(s.angle) * s.r;

      ctx.beginPath();
      ctx.arc(x, y, s.size, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(255,255,255,${opacity.toFixed(3)})`;
      ctx.fill();
    }

    animId = requestAnimationFrame(draw);
  }

  const ro = new ResizeObserver(resize);
  ro.observe(canvas.parentElement);
  resize();
  draw();

  document.addEventListener('astro:before-swap', () => {
    cancelAnimationFrame(animId);
    ro.disconnect();
  }, { once: true });
})();
</script>
